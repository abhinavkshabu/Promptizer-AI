{
    "manifest_version": 3,
    "name": "Promptizer AI",
    "version": "1.0.0",
    "description": "AN AI POWERED PROMPT GENERATOR",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*",
        "https://*.onrender.com/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Open Promptizer Settings",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://gemini.google.com/*",
                "*://claude.ai/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["icons/icon48.png"],
            "matches": [
                "*://chatgpt.com/*",
                "*://gemini.google.com/*",
                "*://claude.ai/*"
            ]
        }
    ]
}